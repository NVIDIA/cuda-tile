10 REM GEMM: C(M,N) = A(M,K) * B(K,N)
20 DIM A(512, 512), B(512, 512), C(512, 512)
30 TILE A(128, 32), B(32, 128), C(128, 128), ACC(128, 128)
40 INPUT A(), B()
50 LET TILEM = BID / 4
60 LET TILEN = BID MOD 4
70 LET ACC = 0.0
80 FOR K = 0 TO 15
90   MMA ACC, A(TILEM, K), B(K, TILEN)
100 NEXT K
110 STORE C(TILEM, TILEN), ACC
120 OUTPUT C
130 END
